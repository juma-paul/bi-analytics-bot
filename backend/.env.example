# === DATABASE CONFIGURATION ===
# For local development with Docker:
# NEON_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/bi_analytics

# For Neon (copy your connection string from Neon dashboard):
# 1. Go to https://console.neon.tech
# 2. Create a new project
# 3. Copy the connection string and paste below:
NEON_DATABASE_URL=postgresql+psycopg://user:password@host/dbname

# === OPENAI CONFIGURATION ===
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# === APP CONFIGURATION ===
DEBUG=False
ENVIRONMENT=production
