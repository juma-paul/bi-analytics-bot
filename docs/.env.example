# === LOCAL DEVELOPMENT (Docker Compose) ===
# For local development, use these settings:
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=bi_analytics

# === PRODUCTION (Neon) ===
# Replace DATABASE_URL with your Neon connection string
# Copy from https://console.neon.tech and replace 'postgresql://' with 'postgresql+psycopg://'
DATABASE_URL=postgresql+psycopg://user:password@ep-xxxxx.us-east-1.neon.tech/dbname?sslmode=require

# === OPENAI API ===
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# === FRONTEND CONFIG ===
NEXT_PUBLIC_API_URL=http://localhost:8000

# === ENVIRONMENT ===
NODE_ENV=development
PYTHON_ENV=development
